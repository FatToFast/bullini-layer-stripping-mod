# Haystack Search Server Environment Configuration

# Server Configuration
HAYSTACK_PORT=7700

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_INDEX=dart_filings
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
EMBEDDING_DIM=768

# Web Search Configuration
# Optional: Set SERPERDEV_API_KEY for better web search results
# Get API key from: https://serper.dev/
SERPERDEV_API_KEY=

# Document Indexing Configuration
DART_RAG_DIR=~/projects/dart_rag
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Logging Configuration
# Available levels: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
